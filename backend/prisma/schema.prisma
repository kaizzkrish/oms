// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?
  deletedBy String?

  createdByUser User? @relation("UserCreatedBy", fields: [createdBy], references: [id])
  updatedByUser User? @relation("UserUpdatedBy", fields: [updatedBy], references: [id])
  deletedByUser User? @relation("UserDeletedBy", fields: [deletedBy], references: [id])

  createdUsers User[] @relation("UserCreatedBy")
  updatedUsers User[] @relation("UserUpdatedBy")
  deletedUsers User[] @relation("UserDeletedBy")

  sessions            Session[]
  passwordResetTokens PasswordResetToken[]

  createdRoles Role[] @relation("RoleCreatedBy")
  updatedRoles Role[] @relation("RoleUpdatedBy")
  deletedRoles Role[] @relation("RoleDeletedBy")

  userRoles         UserRole[] @relation("UserRoleUser")
  assignedUserRoles UserRole[] @relation("UserRoleAssignedBy")

  createdPermissionGroups PermissionGroup[] @relation("PermissionGroupCreatedBy")
  updatedPermissionGroups PermissionGroup[] @relation("PermissionGroupUpdatedBy")
  deletedPermissionGroups PermissionGroup[] @relation("PermissionGroupDeletedBy")

  createdPermissions Permission[] @relation("PermissionCreatedBy")
  updatedPermissions Permission[] @relation("PermissionUpdatedBy")
  deletedPermissions Permission[] @relation("PermissionDeletedBy")

  assignedRolePermissions RolePermission[] @relation("RolePermissionAssignedBy")

  createdOrganizations Organization[] @relation("OrganizationCreatedBy")
  updatedOrganizations Organization[] @relation("OrganizationUpdatedBy")
  deletedOrganizations Organization[] @relation("OrganizationDeletedBy")

  createdOffices Office[] @relation("OfficeCreatedBy")
  updatedOffices Office[] @relation("OfficeUpdatedBy")
  deletedOffices Office[] @relation("OfficeDeletedBy")

  createdDepartments Department[] @relation("DepartmentCreatedBy")
  updatedDepartments Department[] @relation("DepartmentUpdatedBy")
  deletedDepartments Department[] @relation("DepartmentDeletedBy")

  createdDesignations Designation[] @relation("DesignationCreatedBy")
  updatedDesignations Designation[] @relation("DesignationUpdatedBy")
  deletedDesignations Designation[] @relation("DesignationDeletedBy")

  employeeProfile Employee? @relation("EmployeeUser")

  createdEmployees Employee[] @relation("EmployeeCreatedBy")
  updatedEmployees Employee[] @relation("EmployeeUpdatedBy")
  deletedEmployees Employee[] @relation("EmployeeDeletedBy")

  createdTeams Team[] @relation("TeamCreatedBy")
  updatedTeams Team[] @relation("TeamUpdatedBy")
  deletedTeams Team[] @relation("TeamDeletedBy")

  addedTeamMembers TeamMember[] @relation("TeamMemberAddedBy")

  createdClients Client[] @relation("ClientCreatedBy")
  updatedClients Client[] @relation("ClientUpdatedBy")
  deletedClients Client[] @relation("ClientDeletedBy")

  createdProjects Project[] @relation("ProjectCreatedBy")
  updatedProjects Project[] @relation("ProjectUpdatedBy")
  deletedProjects Project[] @relation("ProjectDeletedBy")

  createdProjectModules ProjectModule[] @relation("ProjectModuleCreatedBy")
  updatedProjectModules ProjectModule[] @relation("ProjectModuleUpdatedBy")
  deletedProjectModules ProjectModule[] @relation("ProjectModuleDeletedBy")

  @@index([email])
  @@map("users")
}

model Role {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?
  isSystem    Boolean @default(false)
  isActive    Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?
  deletedBy String?

  createdByUser User? @relation("RoleCreatedBy", fields: [createdBy], references: [id])
  updatedByUser User? @relation("RoleUpdatedBy", fields: [updatedBy], references: [id])
  deletedByUser User? @relation("RoleDeletedBy", fields: [deletedBy], references: [id])

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@index([name])
  @@map("roles")
}

model UserRole {
  id     String @id @default(uuid())
  userId String
  user   User   @relation("UserRoleUser", fields: [userId], references: [id], onDelete: Cascade)
  roleId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now())
  assignedBy String?

  assignedByUser User? @relation("UserRoleAssignedBy", fields: [assignedBy], references: [id])

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model PermissionGroup {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?
  isActive    Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?
  deletedBy String?

  createdByUser User? @relation("PermissionGroupCreatedBy", fields: [createdBy], references: [id])
  updatedByUser User? @relation("PermissionGroupUpdatedBy", fields: [updatedBy], references: [id])
  deletedByUser User? @relation("PermissionGroupDeletedBy", fields: [deletedBy], references: [id])

  permissions Permission[]

  @@index([name])
  @@map("permission_groups")
}

model Permission {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?
  isSystem    Boolean @default(false)
  isActive    Boolean @default(true)

  groupId String?
  group   PermissionGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?
  deletedBy String?

  createdByUser User? @relation("PermissionCreatedBy", fields: [createdBy], references: [id])
  updatedByUser User? @relation("PermissionUpdatedBy", fields: [updatedBy], references: [id])
  deletedByUser User? @relation("PermissionDeletedBy", fields: [deletedBy], references: [id])

  rolePermissions RolePermission[]

  @@index([name])
  @@index([groupId])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now())
  assignedBy String?

  assignedByUser User? @relation("RolePermissionAssignedBy", fields: [assignedBy], references: [id])

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model Organization {
  id                 String  @id @default(uuid())
  name               String  @unique
  legalName          String?
  registrationNumber String?
  industry           String?
  website            String?
  email              String?
  phone              String?
  logoUrl            String?
  isActive           Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?
  deletedBy String?

  createdByUser User? @relation("OrganizationCreatedBy", fields: [createdBy], references: [id])
  updatedByUser User? @relation("OrganizationUpdatedBy", fields: [updatedBy], references: [id])
  deletedByUser User? @relation("OrganizationDeletedBy", fields: [deletedBy], references: [id])

  offices      Office[]
  departments  Department[]
  designations Designation[]
  employees    Employee[]
  teams        Team[]
  clients        Client[]
  projects       Project[]
  projectModules ProjectModule[]

  @@index([name])
  @@map("organizations")
}

model Office {
  id             String  @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name          String
  isHeadquarters Boolean @default(false)
  addressLine1  String
  addressLine2  String?
  city          String
  state         String?
  country       String
  postalCode    String?
  phone         String?
  email         String?
  isActive      Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?
  deletedBy String?

  createdByUser User? @relation("OfficeCreatedBy", fields: [createdBy], references: [id])
  updatedByUser User? @relation("OfficeUpdatedBy", fields: [updatedBy], references: [id])
  deletedByUser User? @relation("OfficeDeletedBy", fields: [deletedBy], references: [id])

  departments Department[]
  employees   Employee[]

  @@index([organizationId])
  @@index([name])
  @@map("offices")
}

model Department {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  officeId       String?
  office         Office?      @relation(fields: [officeId], references: [id], onDelete: SetNull)

  name        String
  code        String?
  description String?
  isActive    Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?
  deletedBy String?

  createdByUser User? @relation("DepartmentCreatedBy", fields: [createdBy], references: [id])
  updatedByUser User? @relation("DepartmentUpdatedBy", fields: [updatedBy], references: [id])
  deletedByUser User? @relation("DepartmentDeletedBy", fields: [deletedBy], references: [id])

  designations Designation[]
  employees    Employee[]
  teams        Team[]
  projects     Project[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([officeId])
  @@map("departments")
}

model Designation {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departmentId   String?
  department     Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  name        String
  code        String?
  description String?
  isActive    Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?
  deletedBy String?

  createdByUser User? @relation("DesignationCreatedBy", fields: [createdBy], references: [id])
  updatedByUser User? @relation("DesignationUpdatedBy", fields: [updatedBy], references: [id])
  deletedByUser User? @relation("DesignationDeletedBy", fields: [deletedBy], references: [id])

  employees Employee[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([departmentId])
  @@map("designations")
}

model Employee {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation("EmployeeUser", fields: [userId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departmentId   String?
  department     Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  designationId  String?
  designation    Designation? @relation(fields: [designationId], references: [id], onDelete: SetNull)
  officeId       String?
  office         Office?      @relation(fields: [officeId], references: [id], onDelete: SetNull)

  reportingManagerId String?
  reportingManager   Employee?  @relation("EmployeeReportingManager", fields: [reportingManagerId], references: [id], onDelete: SetNull)
  directReports      Employee[] @relation("EmployeeReportingManager")

  employeeCode   String
  employmentType String    @default("FULL_TIME")
  dateOfJoining  DateTime
  dateOfLeaving  DateTime?
  phone          String?
  isActive       Boolean   @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?
  deletedBy String?

  createdByUser User? @relation("EmployeeCreatedBy", fields: [createdBy], references: [id])
  updatedByUser User? @relation("EmployeeUpdatedBy", fields: [updatedBy], references: [id])
  deletedByUser User? @relation("EmployeeDeletedBy", fields: [deletedBy], references: [id])

  teamsLed        Team[]          @relation("TeamLeader")
  teamMemberships TeamMember[]
  clientsManaged  Client[]        @relation("ClientAccountManager")
  projectsManaged Project[]       @relation("ProjectManager")
  modulesLed      ProjectModule[] @relation("ProjectModuleLead")

  @@unique([organizationId, employeeCode])
  @@index([organizationId])
  @@index([departmentId])
  @@index([designationId])
  @@index([officeId])
  @@index([reportingManagerId])
  @@map("employees")
}

model Team {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departmentId   String?
  department     Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  teamLeaderId   String?
  teamLeader     Employee?    @relation("TeamLeader", fields: [teamLeaderId], references: [id], onDelete: SetNull)

  name        String
  code        String?
  description String?
  isActive    Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?
  deletedBy String?

  createdByUser User? @relation("TeamCreatedBy", fields: [createdBy], references: [id])
  updatedByUser User? @relation("TeamUpdatedBy", fields: [updatedBy], references: [id])
  deletedByUser User? @relation("TeamDeletedBy", fields: [deletedBy], references: [id])

  members  TeamMember[]
  projects Project[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([departmentId])
  @@index([teamLeaderId])
  @@map("teams")
}

model TeamMember {
  id         String   @id @default(uuid())
  teamId     String
  team       Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now())
  addedBy  String?

  addedByUser User? @relation("TeamMemberAddedBy", fields: [addedBy], references: [id])

  @@unique([teamId, employeeId])
  @@index([teamId])
  @@index([employeeId])
  @@map("team_members")
}

model Client {
  id               String       @id @default(uuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  accountManagerId String?
  accountManager   Employee?    @relation("ClientAccountManager", fields: [accountManagerId], references: [id], onDelete: SetNull)

  name        String
  code        String?
  industry    String?
  website     String?
  email       String?
  phone       String?

  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  country      String?
  postalCode   String?

  contactName  String?
  contactEmail String?
  contactPhone String?

  description String?
  isActive    Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?
  deletedBy String?

  createdByUser User? @relation("ClientCreatedBy", fields: [createdBy], references: [id])
  updatedByUser User? @relation("ClientUpdatedBy", fields: [updatedBy], references: [id])
  deletedByUser User? @relation("ClientDeletedBy", fields: [deletedBy], references: [id])

  projects Project[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([accountManagerId])
  @@map("clients")
}

model Project {
  id                String       @id @default(uuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId          String?
  client            Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  departmentId      String?
  department        Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  projectManagerId  String?
  projectManager    Employee?    @relation("ProjectManager", fields: [projectManagerId], references: [id], onDelete: SetNull)
  teamId            String?
  team              Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)

  name        String
  code        String?
  description String?
  status      String  @default("PLANNING")
  priority    String  @default("MEDIUM")

  startDate DateTime?
  endDate   DateTime?
  budget    Decimal?  @db.Decimal(14, 2)

  isActive Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?
  deletedBy String?

  createdByUser User? @relation("ProjectCreatedBy", fields: [createdBy], references: [id])
  updatedByUser User? @relation("ProjectUpdatedBy", fields: [updatedBy], references: [id])
  deletedByUser User? @relation("ProjectDeletedBy", fields: [deletedBy], references: [id])

  modules ProjectModule[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([clientId])
  @@index([departmentId])
  @@index([projectManagerId])
  @@index([teamId])
  @@map("projects")
}

model ProjectModule {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId      String
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  moduleLeadId   String?
  moduleLead     Employee?    @relation("ProjectModuleLead", fields: [moduleLeadId], references: [id], onDelete: SetNull)

  name        String
  code        String?
  description String?
  status      String  @default("PLANNING")

  startDate DateTime?
  endDate   DateTime?

  isActive Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?
  deletedBy String?

  createdByUser User? @relation("ProjectModuleCreatedBy", fields: [createdBy], references: [id])
  updatedByUser User? @relation("ProjectModuleUpdatedBy", fields: [updatedBy], references: [id])
  deletedByUser User? @relation("ProjectModuleDeletedBy", fields: [deletedBy], references: [id])

  @@unique([projectId, name])
  @@index([organizationId])
  @@index([projectId])
  @@index([moduleLeadId])
  @@map("project_modules")
}

model Session {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("sessions")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}
