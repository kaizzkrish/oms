# ==============================================================================
# Office Management System - Environment Configuration
# Copy this file to `.env` and fill in real values. Never commit the real `.env`.
# ==============================================================================

# ---------- General ----------
NODE_ENV=development
# LAN IP or hostname of the office server that hosts this deployment.
SERVER_HOST=192.168.1.100
APP_NAME=Office Management System

# ---------- Frontend ----------
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://192.168.1.100/api
VITE_APP_NAME=Office Management System

# ---------- Backend (NestJS) ----------
BACKEND_PORT=3000
API_PREFIX=api
SWAGGER_PATH=docs
CORS_ORIGIN=http://192.168.1.100

# ---------- PostgreSQL ----------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=oms_db
POSTGRES_USER=oms_user
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql://oms_user:change_me@postgres:5432/oms_db?schema=public

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me
REDIS_URL=redis://:change_me@redis:6379

# ---------- JWT ----------
JWT_ACCESS_SECRET=change_me_access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# ---------- Password Hashing ----------
# argon2 (preferred) or bcrypt
PASSWORD_HASH_ALGORITHM=argon2

# ---------- SMTP / Email (Nodemailer) ----------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=change_me
SMTP_PASSWORD=change_me
SMTP_FROM_NAME=Office Management System
SMTP_FROM_EMAIL=no-reply@example.com

# ---------- File Storage ----------
STORAGE_DRIVER=local
STORAGE_ROOT=./storage

# ---------- Rate Limiting ----------
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ---------- Logging ----------
LOG_LEVEL=info
