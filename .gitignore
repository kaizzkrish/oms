# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
*.tsbuildinfo

# Environment
.env
.env.*
!.env.example

# Logs
logs/
*.log
npm-debug.log*
pnpm-debug.log*

# Testing
coverage/

# Storage (runtime file storage, keep structure only)
storage/**
!storage/**/
!storage/**/.gitkeep

# Backend's runtime STORAGE_ROOT resolves relative to its own cwd (both
# locally and in Docker), landing here rather than the repo-root storage/
# above — ignore its contents the same way.
backend/storage/**
!backend/storage/**/
!backend/storage/**/.gitkeep

# IDE
.vscode/*
!.vscode/extensions.json
.idea/

# OS
.DS_Store
Thumbs.db

# Prisma
backend/prisma/*.db
backend/src/generated/

# Misc
*.tgz
.eslintcache
